rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================================
    // --- FONCTIONS UTILITAIRES ---
    // ==========================================================
    
    function getUserData() {
      let docRef = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(docRef) ? get(docRef).data : {};
    }

    function isAdmin() {
      return request.auth != null && (getUserData().get('role', '') == 'admin' || getUserData().get('role', '') == 'superadmin');
    }

    function isSeller() {
      return request.auth != null && (getUserData().get('role', '') == 'seller' || getUserData().get('role', '') == 'vendeur');
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function ownsShop(shopId) {
      // Sécurité anti-crash si le shopId est null ou n'existe pas
      return shopId != null 
        && exists(/databases/$(database)/documents/shops/$(shopId))
        && (
          get(/databases/$(database)/documents/shops/$(shopId)).data.ownerEmail == request.auth.token.email ||
          get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid
        );
    }

    function isChatParticipant(chatData) {
      return request.auth != null
        && chatData.participantIds is list
        && chatData.participantIds.hasAny([request.auth.uid]);
    }

    function isChatParticipantById(chatId) {
      let docRef = /databases/$(database)/documents/chats/$(chatId);
      return request.auth != null
        && exists(docRef)
        && get(docRef).data.participantIds is list
        && get(docRef).data.participantIds.hasAny([request.auth.uid]);
    }

    function isDeliverer() {
      return request.auth != null && getUserData().get('role', '') == 'livreur';
    }

    // ==============================
    // --- RÈGLES PAR COLLECTION ---
    // ==============================

    // 1. UTILISATEURS
    match /users/{userId} {
      allow read: if request.auth != null;
      // Faille de sécurité corrigée ici (plus de allow list: if true)
      allow create: if request.auth != null && request.auth.uid == userId;
      allow write: if isOwner(userId) || isAdmin();

      match /{subcol}/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // 2. BOUTIQUES
    match /shops/{shopId} {
      allow read: if true;
      allow create, delete: if isAdmin(); 
      allow update: if isAdmin() || (isSeller() && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.ownerEmail == request.auth.token.email
      ));
    }

    // 3. PRODUITS
    match /{path=**}/products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin() || isSeller();
      allow update: if isAdmin() || isSeller() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']);
    }

    // 4. CATÉGORIES
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. COMMANDES (Logistique UberEats / Glovo)
    match /orders/{orderId} {
      allow create: if request.auth != null;
      
      // LECTURE des commandes
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || isAdmin()
        || ownsShop(resource.data.sellerId)
        // Livreur : Marché des commandes dispos
        || (isDeliverer() && resource.data.status == "ready_for_delivery")
        // Livreur : Ses commandes en cours (tolérance sur courierId ou deliveredBy)
        || (isDeliverer() && resource.data.status == "in_transit" && (resource.data.courierId == request.auth.uid || resource.data.deliveredBy == request.auth.uid))
        // Livreur : Son historique
        || (isDeliverer() && resource.data.status == "delivered" && (resource.data.courierId == request.auth.uid || resource.data.deliveredBy == request.auth.uid))
      );
      
      // MISE À JOUR des commandes
      allow update: if request.auth != null && (
        isAdmin()
        || (isSeller() && ownsShop(resource.data.sellerId))
        
        // Livreur accepte la course (ready -> in_transit)
        || (isDeliverer() 
            && resource.data.status == "ready_for_delivery" 
            && request.resource.data.status == "in_transit"
            && request.resource.data.courierId == request.auth.uid)
            
        // Livreur valide la livraison (in_transit -> delivered)
        || (isDeliverer() 
            && resource.data.status == "in_transit" 
            && request.resource.data.status == "delivered"
            && (resource.data.courierId == request.auth.uid || resource.data.deliveredBy == request.auth.uid))
      );
    }

    // 6. AVIS
    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // 7. PROMOS
    match /promos/{promoId} {
      allow read: if true;
      allow write: if isAdmin() || isSeller();
    }

    // 8. PARAMÈTRES DE LIVRAISON
    match /shipping_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 9. CHATS INTERNES
    match /chats/{chatId} {
      allow create: if request.auth != null
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.buyerId is string
        && request.resource.data.sellerId is string
        && request.resource.data.shopId is string
        && request.resource.data.buyerId != request.resource.data.sellerId
        && request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() == 2
        && request.resource.data.participantIds.hasAll([
          request.resource.data.buyerId,
          request.resource.data.sellerId
        ]);

      allow get: if request.auth != null;
      allow list: if request.auth != null;

      allow update: if isChatParticipant(resource.data)
        && request.resource.data.buyerId == resource.data.buyerId
        && request.resource.data.sellerId == resource.data.sellerId
        && request.resource.data.shopId == resource.data.shopId
        && request.resource.data.participantIds == resource.data.participantIds;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if request.auth != null;

        allow create: if isChatParticipantById(chatId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1200;

        allow update, delete: if false;
      }
    }
  }
}