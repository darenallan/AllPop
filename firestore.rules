rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════════════
    // FONCTIONS UTILITAIRES
    // ══════════════════════════════════════════════════════════════════════

    function getUserData() {
      let docRef = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(docRef) ? get(docRef).data : {};
    }

    function isAdmin() {
      return request.auth != null && (
        getUserData().get('role', '') == 'admin' ||
        getUserData().get('role', '') == 'superadmin'
      );
    }

    function isSeller() {
      return request.auth != null && (
        getUserData().get('role', '') == 'seller' ||
        getUserData().get('role', '') == 'vendeur'
      );
    }

    function isDeliverer() {
      return request.auth != null && getUserData().get('role', '') == 'livreur';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function ownsShop(shopId) {
      return shopId != null
        && exists(/databases/$(database)/documents/shops/$(shopId))
        && (
          get(/databases/$(database)/documents/shops/$(shopId)).data.ownerEmail == request.auth.token.email
          || get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid
        );
    }

    function isChatParticipant(chatData) {
      return request.auth != null
        && chatData.participantIds is list
        && chatData.participantIds.hasAny([request.auth.uid]);
    }

    function isChatParticipantById(chatId) {
      let docRef = /databases/$(database)/documents/chats/$(chatId);
      return request.auth != null
        && exists(docRef)
        && get(docRef).data.participantIds is list
        && get(docRef).data.participantIds.hasAny([request.auth.uid]);
    }

    // ══════════════════════════════════════════════════════════════════════
    // 1. UTILISATEURS
    // ══════════════════════════════════════════════════════════════════════
    match /users/{userId} {
      allow get:  if request.auth != null;
      allow list: if isAdmin();
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid   == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.role  == 'client';
      allow update, delete: if isOwner(userId) || isAdmin();
      match /{subcol}/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ══════════════════════════════════════════════════════════════════════
    // 2. BOUTIQUES & CANDIDATURES
    // ══════════════════════════════════════════════════════════════════════
    match /shops/{shopId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSeller() && (
        resource.data.ownerId    == request.auth.uid ||
        resource.data.ownerEmail == request.auth.token.email
      ));
    }

    match /seller_applications/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // 3. PRODUITS
    // ══════════════════════════════════════════════════════════════════════
    match /{path=**}/products/{productId} {
      allow read: if true;
      allow create: if isAdmin()
        || (isSeller()
            && request.resource.data.shopId != null
            && ownsShop(request.resource.data.shopId));
      allow update: if isAdmin()
        || (isSeller() && ownsShop(resource.data.shopId))
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']);
      allow delete: if isAdmin()
        || (isSeller() && ownsShop(resource.data.shopId));
    }

    // ══════════════════════════════════════════════════════════════════════
    // 4. CATÉGORIES
    // ══════════════════════════════════════════════════════════════════════
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // 5. COMMANDES
    // FIX CRITIQUE : "uid in resource.data.sellerIds" → .hasAny([uid])
    // ══════════════════════════════════════════════════════════════════════
    match /orders/{orderId} {
      allow create: if request.auth != null;

      allow read: if request.auth != null && (
        isAdmin()
        || resource.data.userId == request.auth.uid
        // FIX : hasAny() est la syntaxe correcte pour tester un tableau
        || (isSeller()
            && 'sellerIds' in resource.data
            && resource.data.sellerIds is list
            && resource.data.sellerIds.hasAny([request.auth.uid]))
        || (isDeliverer() && (
             resource.data.status == 'ready_for_delivery'
             || (resource.data.status in ['in_transit', 'delivered']
                 && (resource.data.courierId == request.auth.uid
                     || resource.data.deliveredBy == request.auth.uid))
           ))
      );

      allow update: if request.auth != null && (
        isAdmin()
        || (isSeller()
            && 'sellerIds' in resource.data
            && resource.data.sellerIds is list
            && resource.data.sellerIds.hasAny([request.auth.uid])
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['sellerStatuses', 'status', 'updatedAt']))
        || (isDeliverer()
            && resource.data.status == 'ready_for_delivery'
            && request.resource.data.status == 'in_transit'
            && request.resource.data.courierId == request.auth.uid)
        || (isDeliverer()
            && resource.data.status == 'in_transit'
            && request.resource.data.status == 'delivered'
            && resource.data.courierId == request.auth.uid)
      );

      match /sub_orders/{subOrderId} {
        allow read: if request.auth != null && (
          isAdmin() || isSeller() || resource.data.userId == request.auth.uid
        );
        allow write: if request.auth != null && (isAdmin() || isSeller());
      }
    }

    match /subOrders/{subOrderId} {
      allow read: if request.auth != null && (
        isAdmin() || isSeller() || resource.data.userId == request.auth.uid
      );
      allow write: if request.auth != null && (isAdmin() || isSeller());
    }

    // ══════════════════════════════════════════════════════════════════════
    // 6. AVIS
    // ══════════════════════════════════════════════════════════════════════
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ══════════════════════════════════════════════════════════════════════
    // 7. PROMOS
    // ══════════════════════════════════════════════════════════════════════
    match /promos/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // 8. PARAMÈTRES DE LIVRAISON
    // ══════════════════════════════════════════════════════════════════════
    match /shipping_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // 9. META (compteur de factures)
    // ══════════════════════════════════════════════════════════════════════
    match /meta/invoiceCounter {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(['value'])
        && request.resource.data.value is int
        && request.resource.data.value > 0;
    }
    match /meta/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // 10. NEWSLETTER
    // ══════════════════════════════════════════════════════════════════════
    match /newsletter/{emailId} {
      allow read: if isAdmin();
      allow create: if
        request.resource.data.email is string &&
        request.resource.data.email.size() < 100 &&
        request.resource.data.email.matches('.*@.*\\..*');
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // 11. CHATS INTERNES
    // ══════════════════════════════════════════════════════════════════════
    match /chats/{chatId} {
      allow create: if request.auth != null
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.buyerId is string
        && request.resource.data.sellerId is string
        && request.resource.data.shopId is string
        && request.resource.data.buyerId != request.resource.data.sellerId
        && request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() == 2
        && request.resource.data.participantIds.hasAll([
          request.resource.data.buyerId,
          request.resource.data.sellerId
        ]);
      allow get:  if request.auth != null && isChatParticipant(resource.data);
      allow list: if request.auth != null;
      allow update: if isChatParticipant(resource.data)
        && request.resource.data.buyerId        == resource.data.buyerId
        && request.resource.data.sellerId       == resource.data.sellerId
        && request.resource.data.shopId         == resource.data.shopId
        && request.resource.data.participantIds == resource.data.participantIds;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if request.auth != null && isChatParticipantById(chatId);
        allow create: if isChatParticipantById(chatId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1200;
        allow update, delete: if false;
      }
    }

    // ══════════════════════════════════════════════════════════════════════
    // 12. CONVERSATIONS
    // ══════════════════════════════════════════════════════════════════════
    match /conversations/{conversationId} {
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.participants ||
        request.auth.uid == resource.data.buyerId ||
        request.auth.uid == resource.data.sellerId
      );
      allow create: if request.auth != null && (
        request.auth.uid in request.resource.data.participants ||
        request.auth.uid == request.resource.data.buyerId
      );
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.participants ||
        request.auth.uid == resource.data.buyerId ||
        request.auth.uid == resource.data.sellerId
      );
      match /messages/{messageId} {
        allow read, write: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants ||
          request.auth.uid == get(/databases/$(database)/documents/conversations/$(conversationId)).data.buyerId ||
          request.auth.uid == get(/databases/$(database)/documents/conversations/$(conversationId)).data.sellerId
        );
      }
    }

    // ══════════════════════════════════════════════════════════════════════
    // 13. MESSAGES DE CONTACT
    // ══════════════════════════════════════════════════════════════════════
    match /contacts/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

  }
}
